Cell[TextData[{
 StyleBox["1. a)",
  FontWeight->"Bold"],
 " Z ukazom \[OpenCurlyQuote]Directory\[CloseCurlyQuote] preveri delovno \
podro\[CHacek]je. Nato z uporabo \[OpenCurlyQuote]SetDirectory\
\[CloseCurlyQuote] in \[OpenCurlyQuote]NotebookDirectory\[CloseCurlyQuote] \
nastavi delovno podro\[CHacek]je na ustrezno mapo. \n"
}], "Text",
 CellChangeTimes->{{3.9851475360099773`*^9, 3.9851476054689465`*^9}, {
   3.98523957599275*^9, 3.985239589442259*^9}, 
   3.985323867631962*^9},ExpressionUUID->"b282c310-1783-44a0-b5cc-\
4217572a8639"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{"Directory", "[", "]"}], "\[IndentingNewLine]", 
 RowBox[{"SetDirectory", "[", 
  RowBox[{"NotebookDirectory", "[", "]"}], "]"}]}], "Input",
 CellChangeTimes->{{3.985323874044628*^9, 3.9853239131593113`*^9}},
 CellLabel->"In[1]:=",ExpressionUUID->"49ea3d56-760d-0c4b-98da-815e1c1c3973"],

